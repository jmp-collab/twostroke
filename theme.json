{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "base",
					"color": "#101214",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#f4f4f2",
					"name": "Contrast"
				},
				{
					"slug": "accent",
					"color": "#ff5c1a",
					"name": "Accent"
				},
				{
					"slug": "panel",
					"color": "#1b2025",
					"name": "Panel"
				},
				{
					"slug": "muted",
					"color": "#9aa3ab",
					"name": "Muted"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "System Sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
				},
				{
					"slug": "mono",
					"name": "System Mono",
					"fontFamily": "ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.375rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2rem",
					"name": "Extra Large",
					"fluid": {
						"min": "1.6rem",
						"max": "2.4rem"
					}
				},
				{
					"slug": "xx-large",
					"size": "3rem",
					"name": "Huge",
					"fluid": {
						"min": "2.2rem",
						"max": "3.6rem"
					}
				}
			]
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			],
			"spacingSizes": [
				{
					"slug": "30",
					"size": "0.75rem",
					"name": "1"
				},
				{
					"slug": "40",
					"size": "1.25rem",
					"name": "2"
				},
				{
					"slug": "50",
					"size": "2rem",
					"name": "3"
				},
				{
					"slug": "60",
					"size": "3.5rem",
					"name": "4"
				},
				{
					"slug": "70",
					"size": "5.5rem",
					"name": "5"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|sans",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var:preset|color|accent"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|contrast"
					}
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.15",
					"textTransform": "uppercase",
					"letterSpacing": "0.02em"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|accent",
					"text": "var:preset|color|base"
				},
				"typography": {
					"fontWeight": "700",
					"textTransform": "uppercase",
					"letterSpacing": "0.04em"
				},
				"border": {
					"radius": "0px"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|contrast",
						"text": "var:preset|color|base"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontWeight": "700",
					"textTransform": "uppercase",
					"letterSpacing": "0.06em",
					"fontSize": "var:preset|font-size|large"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"core/post-date": {
				"color": {
					"text": "var:preset|color|muted"
				},
				"typography": {
					"fontSize": "var:preset|font-size|small"
				}
			},
			"core/post-terms": {
				"color": {
					"text": "var:preset|color|muted"
				},
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var:preset|color|muted"
				}
			},
			"core/separator": {
				"color": {
					"text": "var:preset|color|panel"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var:preset|color|accent",
						"width": "3px",
						"style": "solid"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-landing",
			"title": "Landing (no title)",
			"postTypes": [
				"page"
			]
		}
	]
}
